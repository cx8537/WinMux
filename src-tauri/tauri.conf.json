{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinMux",
  "version": "0.1.0",
  "identifier": "com.cx8537.winmux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WinMux",
        "width": 1280,
        "height": 800,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Windows-native terminal multiplexer.",
    "longDescription": "WinMux is a Windows-native terminal multiplexer with tmux-style session semantics.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English", "Korean"]
      }
    }
  }
}
