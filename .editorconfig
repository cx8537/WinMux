root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

[*.rs]
indent_size = 4

[*.{ts,tsx,js,jsx,json,jsonc,css,html,yml,yaml}]
indent_size = 2

[*.toml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{ps1,bat,cmd}]
end_of_line = crlf
